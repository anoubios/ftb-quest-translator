{
  "schemaVersion": 1,
  "id": "${id}",
  "version": "${version}",
  "name": "${name}",
  "description": "Addon for FTB Quests that adds a translate button to the quest view panel. Translates quest title, subtitle and description on-the-fly using free translation APIs.",
  "authors": ["anoubios"],
  "contact": {
    "homepage": "https://github.com/anoubios/ftb-quest-translator",
    "sources": "https://github.com/anoubios/ftb-quest-translator",
    "issues": "https://github.com/anoubios/ftb-quest-translator/issues"
  },
  "license": "MIT",
  "icon": "assets/ftbquesttransl/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.fqt.fqtmod.FTBQuestTranslatorFabric"
    ]
  },
  "mixins": [
    "ftbquesttransl.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "~${minecraft_version}",
    "java": ">=17",
    "ftbquests": "*",
    "ftblibrary": "*"
  }
}
